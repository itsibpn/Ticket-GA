{
  "apps": [
    {
      "name": "ga-ticket-backend",
      "script": "backend/server.js",
      "instances": "max",
      "exec_mode": "cluster",
      "env": {
        "NODE_ENV": "production",
        "PORT": 5000
      },
      "watch": false,
      "max_memory_restart": "300M",
      "error_file": "logs/err.log",
      "out_file": "logs/out.log",
      "merge_logs": true
    }
  ]
}
